@page "/set-password"
@using AdminPanel.Domain.Models.Auth.Requests
@using Refit
@inject IAuthApi Api
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<h2>Установка пароля</h2>

<EditForm Model="@_model" OnValidSubmit="@HandleSetPassword">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-group">
        <label>Пароль</label>
        <InputText type="password" @bind-Value="_model.Password" class="form-control" />
    </div>
    <div class="form-group">
        <label>Повторите пароль</label>
        <InputText type="password" @bind-Value="_model.ConfirmPassword" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Установить пароль</button>
</EditForm>

@code {
    [Parameter][SupplyParameterFromQuery] public string Login { get; set; }

    private SetPasswordRequest _model = new();

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Login))
            _model.Login = Login;
    }

    private async Task HandleSetPassword()
    {
        try
        {
            await Api.SetPasswordAsync(_model);
            await JSRuntime.InvokeVoidAsync("alert", "Пароль установлен. Теперь вы можете войти.");
            Navigation.NavigateTo("/login");
        }
        catch (ApiException ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Ошибка: " + ex.Message);
        }
    }
}