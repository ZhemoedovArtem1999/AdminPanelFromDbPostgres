@page "/{Schema}/table/{TableName}"
@using System.Globalization
@inject DatabaseSchemaService SchemaService
@inject TableDataService DataService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<h1>@_descriptionScheme.@_descriptionTable</h1>

<!-- Панель поиска (отображается только если данные загружены) -->
@if (_columns != null)
{
    <!-- Панель поиска -->
    <div class="card mb-3">
        <div class="card-header">
            <h5>🔍 Поиск</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <!-- Выбор поля -->
                <div class="col-md-3">
                    <label>Поле</label>
                    <select value="@_newCondition.FieldName" @onchange="OnFieldChanged" class="form-control">
                        <option value="">-- Выберите поле --</option>
                        @foreach (var col in _columns)
                        {
                            <option value="@col.ColumnName">@col.DisplayName (@col.DataType)</option>
                        }
                    </select>
                </div>

                <!-- Выбор оператора (доступен только если выбрано поле) -->
                <div class="col-md-3">
                    <label>Оператор</label>
                    <select @bind="_newCondition.Operator"
                            disabled="@(string.IsNullOrEmpty(_newCondition.FieldName))"
                            class="form-control">
                        @if (string.IsNullOrWhiteSpace(_newCondition.FieldName))
                        {
                            
                        }
                        else if (IsBooleanColumn(_newCondition.FieldName))
                        {
                            <option value="equals">@OperatorNames["equals"]</option>
                        }
                        else if (IsTextColumn(_newCondition.FieldName))
                        {
                            <option value="contains">@OperatorNames["contains"]</option>
                            <option value="equals">@OperatorNames["equals"]</option>
                            <option value="startswith">@OperatorNames["startswith"]</option>
                        }
                        else if (IsNumericColumn(_newCondition.FieldName) || IsDateColumn(_newCondition.FieldName))
                        {
                            <option value="equals">@OperatorNames["equals"]</option>
                            <option value="gt">@OperatorNames["gt"]</option>
                            <option value="lt">@OperatorNames["lt"]</option>
                        }
                        else
                        {
                            <option value="equals">@OperatorNames["equals"]</option>
                            <option value="contains">@OperatorNames["contains"]</option>
                        }
                    </select>
                </div>

                <!-- Ввод значения (доступен только если выбрано поле) -->
                <div class="col-md-3">
                    <label>Значение</label>
                    @if (IsBooleanColumn(_newCondition.FieldName))
                    {
                        <select @bind="_newCondition.Value"
                                disabled="@(string.IsNullOrEmpty(_newCondition.FieldName))"
                                class="form-control">
                            <option value="">-- Выберите --</option>
                            <option value="true">Да</option>
                            <option value="false">Нет</option>
                        </select>
                    }
                    else
                    {
                        <input type="text"
                               @bind="_newCondition.Value"
                               disabled="@(string.IsNullOrEmpty(_newCondition.FieldName))"
                               class="form-control"
                               placeholder="значение" />
                    }
                </div>

                <!-- Кнопка добавления условия -->
                <div class="col-md-3">
                    <label>&nbsp;</label>
                    <button class="btn btn-primary form-control" @onclick="AddCondition">➕ Добавить</button>
                </div>
            </div>

            <!-- Список активных фильтров (без изменений) -->
            @if (_searchConditions.Any())
            {
                <div class="mt-3">
                    <h6>Активные фильтры:</h6>
                    <ul class="list-group">
                        @foreach (var cond in _searchConditions)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @cond.FieldName @cond.Operator '@cond.Value'
                                <button class="btn btn-sm btn-danger" @onclick="() => RemoveCondition(cond)">✖</button>
                            </li>
                        }
                    </ul>
                    <button class="btn btn-secondary mt-2" @onclick="ClearConditions">Сбросить все</button>
                </div>
            }

            <!-- Кнопка применения поиска -->
            <button class="btn btn-success mt-3" @onclick="ApplySearch">🔎 Применить поиск</button>
        </div>
    </div>
  
}

<!-- Кнопка добавления записи (доступна только когда колонки загружены) -->
@if (_columns != null)
{
    <button class="btn btn-primary mb-3" @onclick="ShowAddModal">➕ Добавить запись</button>
}

@if (_columns == null || _data == null)
{
    <p>Загрузка...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                @foreach (var col in _columns)
                {
                    <th>@col.DisplayName</th>
                }
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _data)
            {
                var currentRow = row;
                <tr @key="row[_primaryKeys.FirstOrDefault()]">
                    @foreach (var col in _columns)
                    {
                        @* <td>@row[col.ColumnName]</td> *@
                        <td>@FormatValueForDisplay(row[col.ColumnName], col.DataType)</td>
                    }
                    <td>
                        <button class="btn btn-sm btn-warning" @onclick="() => EditRow(row)">Редактировать</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteRow(currentRow)">
                            Удалить 
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

   <nav aria-label="Пример навигации по страницам">
   <ul class="pagination">
        <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
            <a class="page-link" 
               style="cursor: pointer;" 
               aria-label="Предыдущая" 
               @onclick="PrevPage"
               >
                <span aria-hidden="true">&laquo;</span>
            </a>
        </li>
        <li class="page-item">
            <a class="page-link">
                <span>Стр. @_currentPage</span>
            </a>
        </li>
            <li class="page-item @(_currentPage >= _totalPages ? "disabled" : "")">
               <a class="page-link"
               style="cursor: pointer;" 
               aria-label="Следующая" 
               @onclick="NextPage"
               >
                <span aria-hidden="true">&raquo;</span>
            </a>
        </li>
    </ul>
</nav>
}

@if (_showModal)
{
    <div class="modal" style="display:block; background-color:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEdit ? "Редактирование записи" : "Добавление записи")</h5>
                    <button type="button" class="close ms-auto bg-transparent" style="border: none;" @onclick="CloseModal">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    @foreach (var col in _columns)
                    {
                        if (col.IsAutoIncrement) continue;

                        var isRequired = !col.IsNullable;
                        var hasError = _validationErrors.ContainsKey(col.ColumnName);
                        var inputType = GetInputType(col.DataType);
                        var inputStep = GetInputStep(col.DataType);

                        <div class="form-group">
                            <label>
                                @col.DisplayName (@col.DataType)
                                @if (isRequired)
                                {
                                    <span class="text-danger" title="Обязательное поле">*</span>
                                }
                            </label>

                            @if (inputType == "textarea")
                            {
                                <textarea class="form-control @(hasError ? "is-invalid" : "")"
                                          value="@GetEditValue(col.ColumnName)"
                                          @onchange="@((ChangeEventArgs e) => SetEditValue(col.ColumnName, e.Value?.ToString()))"
                                          rows="3">
                        </textarea>
                            }
                            else if (inputType == "checkbox")
                            {
                                <div class="form-check">
                                    <input type="checkbox"
                                           class="form-check-input @(hasError ? "is-invalid" : "")"
                                           checked="@(GetEditValue(col.ColumnName) == "True" || GetEditValue(col.ColumnName) == "true" || GetEditValue(col.ColumnName) == "1")"
                                           @onchange="@((ChangeEventArgs e) => SetEditValue(col.ColumnName, e.Value?.ToString()))" />
                                    <label class="form-check-label">Да/Нет</label>
                                </div>
                            }
                            else if (inputType == "select")
                            {
                                <select class="form-control @(hasError ? "is-invalid" : "")"
                                        value="@GetEditValue(col.ColumnName)"
                                        @onchange="@((ChangeEventArgs e) => SetEditValue(col.ColumnName, e.Value?.ToString()))">
                                    <option value="">-- Выберите --</option>
                                    @if (col.DataType.Contains("bool"))
                                    {
                                        <option value="true">Да</option>
                                        <option value="false">Нет</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="@inputType"
                                       class="form-control @(hasError ? "is-invalid" : "")"
                                       value="@GetEditValue(col.ColumnName)"
                                       step="@inputStep"
                                       @onchange="@((ChangeEventArgs e) => SetEditValue(col.ColumnName, e.Value?.ToString()))" />
                            }

                            @if (hasError)
                            {
                                <div class="invalid-feedback">@_validationErrors[col.ColumnName]</div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveRecord">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Schema { get; set; }
    [Parameter] public string TableName { get; set; }

    private Dictionary<string, string> OperatorNames = new Dictionary<string, string>
    {
        {"contains", "Содержит"},      
        {"equals", "Равно"},
        {"startswith", "Начинается с"},
        {"gt", "Больше"},
        {"lt", "Меньше"},      
    };

    private string _descriptionScheme;
    private string _descriptionTable;

    private List<ColumnInfo> _columns;
    private List<string> _primaryKeys;
    private List<Dictionary<string, object>> _data;
    private int _currentPage = 1;
    private const int PageSize = 20;
    private int _totalCount;
    private int _totalPages => (_totalCount + PageSize - 1) / PageSize;

    private bool _showModal;
    private bool _isEdit;
    private Dictionary<string, object> _editValues = new();
    private Dictionary<string, object> _originalKeyValues; 

    private Dictionary<string, string> _validationErrors = new();

    private List<SearchCondition> _searchConditions = new();
    private SearchCondition _newCondition = new();

    protected override async Task OnParametersSetAsync()
    {
        await LoadMetadataAsync();
        await LoadTotalCountAsync();
        await LoadDataAsync();
        _newCondition = new SearchCondition(); // гарантируем чистоту
    }

    private async Task LoadMetadataAsync()
    {
        _descriptionScheme = await SchemaService.GetSchemaDescriptionAsync(Schema) ?? Schema;
        _descriptionTable = await SchemaService.GetTableDescriptionAsync(Schema, TableName) ?? TableName;
        _columns = (await SchemaService.GetColumnsAsync(Schema, TableName)) ?? new List<ColumnInfo>();
        _primaryKeys = (await SchemaService.GetPrimaryKeyColumnsAsync(Schema, TableName)) ?? new List<string>();
    }

    private async Task LoadDataAsync()
    {
        var orderByColumn = _primaryKeys.FirstOrDefault() ?? "id";
        _data = await DataService.GetDataAsync(
            Schema,
            TableName,
            orderByColumn,
            _searchConditions,
            _columns,
            _currentPage,
            PageSize);
    }

    private async Task LoadTotalCountAsync()
    {
        _totalCount = await DataService.GetCountAsync(
            Schema,
            TableName,
            _searchConditions,
            _columns);
    }

    private async Task NextPage()
    {
        _currentPage++;
        await LoadDataAsync();
    }

    private async Task PrevPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await LoadDataAsync();
        }
    }

    private void OnFieldChanged(ChangeEventArgs e)
    {
        _newCondition.FieldName = e.Value?.ToString();
        // Устанавливаем оператор по умолчанию в зависимости от типа поля
        _newCondition.Operator = GetDefaultOperatorForField(_newCondition.FieldName);
        _newCondition.Value = null;
        _newCondition.Operator = null;

    }

    private string GetDefaultOperatorForField(string fieldName)
    {
        if (string.IsNullOrEmpty(fieldName)) return "contains";
        if (IsBooleanColumn(fieldName)) return "equals";
        if (IsTextColumn(fieldName)) return "contains";
        if (IsNumericColumn(fieldName) || IsDateColumn(fieldName)) return "equals";
        return "contains";
    }

    private void AddCondition()
    {
        if (!string.IsNullOrWhiteSpace(_newCondition.FieldName) &&
            !string.IsNullOrWhiteSpace(_newCondition.Value))
        {
            _searchConditions.Add(new SearchCondition
            {
                FieldName = _newCondition.FieldName,
                Operator = string.IsNullOrEmpty(_newCondition.Operator)
                    ? GetDefaultOperatorForField(_newCondition.FieldName)
                    : _newCondition.Operator,
                Value = _newCondition.Value
            });
            _newCondition = new SearchCondition(); // сброс
        }
    }

    private void RemoveCondition(SearchCondition cond)
    {
        _searchConditions.Remove(cond);
    }

    private void ClearConditions()
    {
        _searchConditions.Clear();
    }

    private async Task ApplySearch()
    {
        _currentPage = 1;
        await LoadTotalCountAsync();
        await LoadDataAsync();
    }

    private bool IsTextColumn(string fieldName)
    {
        var col = _columns.FirstOrDefault(c => c.ColumnName == fieldName);
        return col != null && IsTextType(col.DataType);
    }

    private bool IsNumericColumn(string fieldName)
    {
        var col = _columns.FirstOrDefault(c => c.ColumnName == fieldName);
        return col != null && IsNumericType(col.DataType);
    }

    private bool IsDateColumn(string fieldName)
    {
        var col = _columns.FirstOrDefault(c => c.ColumnName == fieldName);
        return col != null && IsDateType(col.DataType);
    }

    private bool IsBooleanColumn(string fieldName)
    {
        if (string.IsNullOrEmpty(fieldName)) return false;
        var col = _columns?.FirstOrDefault(c => c.ColumnName == fieldName);
        return col != null && IsBooleanType(col.DataType);
    }

    private bool IsTextType(string type) =>
        new[] { "string", "text", "varchar", "char" }.Contains(type?.ToLower());

    private bool IsNumericType(string type) =>
        new[] { "int", "long", "decimal", "double", "float", "short", "byte", "numeric", "integer" }.Contains(type?.ToLower());

    private bool IsDateType(string type) =>
        new[] { "datetime", "date", "time", "timestamp", "timestamp with time zone" }.Contains(type?.ToLower());

    private bool IsBooleanType(string type)
    {
        if (string.IsNullOrEmpty(type)) return false;
        var lower = type.ToLower();
        return lower.Contains("bool");
    }

    private void ShowAddModal()
    {
        _isEdit = false;
        _editValues = new Dictionary<string, object>();
        foreach (var col in _columns.Where(c => !c.IsAutoIncrement))
        {
            _editValues[col.ColumnName] = null;
        }
        _showModal = true;
    }

    private void EditRow(Dictionary<string, object> row)
    {
        _isEdit = true;

        Console.WriteLine("=== Редактирование строки (исходные данные) ===");
        foreach (var kvp in row)
        {
            var col = _columns.FirstOrDefault(c => c.ColumnName == kvp.Key);
            var type = col?.DataType ?? "unknown";
            Console.WriteLine($"{kvp.Key}: {kvp.Value} (тип БД: {type}, тип .NET: {kvp.Value?.GetType()})");
        }

        _editValues = new Dictionary<string, object>();

        foreach (var kvp in row)
        {
            var col = _columns.FirstOrDefault(c => c.ColumnName == kvp.Key);
            if (col != null)
            {
                var formattedValue = FormatValueForInput(kvp.Value, col.DataType);
                _editValues[kvp.Key] = formattedValue;

                Console.WriteLine($"{kvp.Key} -> {formattedValue} (форматировано для input)");
            }
            else
            {
                _editValues[kvp.Key] = kvp.Value?.ToString() ?? "";
            }
        }

        _originalKeyValues = new Dictionary<string, object>();
        foreach (var pk in _primaryKeys)
        {
            _originalKeyValues[pk] = row[pk];
        }

        _showModal = true;
    }

    private string FormatValueForDisplay(object value, string dataType)
    {
        if (value == null || value == DBNull.Value)
            return "";

        var lower = dataType.ToLowerInvariant();
        if (lower.Contains("bool"))
        {
            // Преобразуем в bool, если ещё не
            bool boolVal = value is bool b ? b : (value.ToString() == "True");
            return boolVal ? "Да" : "Нет";
        }

        return lower switch
        {
            "date" when value is DateTime dt => dt.ToString("dd.MM.yyyy"),
            "timestamp" when value is DateTime ts => ts.ToString("dd.MM.yyyy HH:mm:ss"),
            "numeric" or "decimal" when value is decimal d => d.ToString(CultureInfo.CurrentCulture),
            _ => value.ToString()
        };
    }

    private object FormatValueForInput(object value, string dataType)
    {
        if (value == null || value == DBNull.Value)
            return "";

        switch (dataType.ToLowerInvariant())
        {
            case "date":
                // Для input type="date" нужен формат YYYY-MM-DD
                if (value is DateTime dateTime)
                    return dateTime.ToString("yyyy-MM-dd");
                if (value is DateOnly dateOnly)
                    return dateOnly.ToString("yyyy-MM-dd");
                break;

            case "timestamp":
            case "timestamp without time zone":
            case "timestamptz":
            case "timestamp with time zone":
                // Для input type="datetime-local" нужен формат YYYY-MM-DDTHH:mm:ss
                if (value is DateTime timestamp)
                    return timestamp.ToString("yyyy-MM-ddTHH:mm:ss");
                break;

            case "time":
            case "time without time zone":
                // Для input type="time" нужен формат HH:mm:ss
                if (value is TimeSpan timeSpan)
                    return timeSpan.ToString(@"hh\:mm\:ss");
                if (value is DateTime time)
                    return time.ToString("HH:mm:ss");
                if (value is TimeOnly timeOnly)
                    return timeOnly.ToString("HH:mm:ss");
                break;

            case "numeric":
            case "decimal":
            case "real":
            case "float4":
            case "double precision":
            case "float8":
                // Для чисел используем инвариантную культуру (с точкой)
                if (value is decimal decimalValue)
                    return decimalValue.ToString(CultureInfo.InvariantCulture);
                if (value is float floatValue)
                    return floatValue.ToString(CultureInfo.InvariantCulture);
                if (value is double doubleValue)
                    return doubleValue.ToString(CultureInfo.InvariantCulture);
                break;
        }

        return value.ToString();
    }



    private async Task DeleteRow(Dictionary<string, object> row)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Удалить запись?");
        if (!confirmed) return;

        var keyValues = new Dictionary<string, object>();
        foreach (var pk in _primaryKeys)
        {
            keyValues[pk] = row[pk];
        }
        await DataService.DeleteAsync(Schema, TableName, keyValues);
        await LoadDataAsync();
    }

    private async Task SaveRecord()
    {
        _validationErrors.Clear();
        bool hasErrors = false;

        foreach (var col in _columns.Where(c => !c.IsAutoIncrement))
        {
            var value = GetEditValue(col.ColumnName);
            var error = ValidateField(col, value);

            if (!string.IsNullOrEmpty(error))
            {
                _validationErrors[col.ColumnName] = error;
                hasErrors = true;
            }
        }

        if (hasErrors)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Пожалуйста, исправьте ошибки в форме");
            return;
        }

        // Преобразование и сохранение
        try
        {
            var convertedValues = new Dictionary<string, object>();
            foreach (var col in _columns.Where(c => !c.IsAutoIncrement))
            {
                var value = GetEditValue(col.ColumnName);
                convertedValues[col.ColumnName] = ConvertValue(value, col);
            }

            if (_isEdit)
            {
                await DataService.UpdateAsync(Schema, TableName, convertedValues, _primaryKeys, _originalKeyValues);
            }
            else
            {
                await DataService.InsertAsync(Schema, TableName, convertedValues);
            }

            _showModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка сохранения: {ex.Message}");
        }
    }


    private void CloseModal() => _showModal = false;

    private string GetEditValue(string columnName)
    {
        if (_editValues != null && _editValues.TryGetValue(columnName, out var value) && value != null)
        {
            return value.ToString();
        }
        return string.Empty;
    }

    private void SetEditValue(string columnName, string value)
    {
        if (_editValues == null)
            _editValues = new Dictionary<string, object>();

        _editValues[columnName] = value;
    }

