    // Определение типа input по типу данных PostgreSQL
    private string GetInputType(string dataType)
    {
        return dataType.ToLowerInvariant() switch
        {
            // Числовые типы
            "integer" or "int" or "int4" or "smallint" or "int2" or "bigint" or "int8" => "number",
            "numeric" or "decimal" or "real" or "float4" or "double precision" or "float8" => "number",
            
            // Типы дат и времени
            "date" => "date",
            "time" or "time without time zone" or "timetz" => "time",
            "timestamp" or "timestamp without time zone" or "timestamptz" or "timestamp with time zone" => "datetime-local",
            
            // Логический тип
            "boolean" or "bool" => "checkbox",
            
            // JSON типы - оставляем текстовое поле
            "json" or "jsonb" => "textarea",
            
            // Текстовые типы
            "text" or "character varying" or "varchar" or "char" or "character" => "text",
            
            // UUID
            "uuid" => "text",

            // По умолчанию
            _ => "text"
        };
    }

    // Шаг для числовых полей
    private string GetInputStep(string dataType)
    {
        return dataType.ToLowerInvariant() switch
        {
            "integer" or "int" or "int4" or "smallint" or "int2" or "bigint" or "int8" => "1",
            "numeric" or "decimal" or "real" or "float4" or "double precision" or "float8" => "0.01",
            _ => null
        };
    }

    private string ValidateField(ColumnInfo col, string value)
    {
        // Проверка обязательности
        if (!col.IsNullable && string.IsNullOrWhiteSpace(value))
            return "Поле обязательно для заполнения";

        if (string.IsNullOrWhiteSpace(value))
            return null;

        try
        {
            switch (col.DataType.ToLowerInvariant())
            {
                case "integer":
                case "int":
                case "int4":
                case "smallint":
                case "int2":
                    ParseInt(value); // Просто проверяем, что парсится
                    break;

                case "bigint":
                case "int8":
                    ParseLong(value);
                    break;

                case "numeric":
                case "decimal":
                    ParseDecimal(value);
                    break;

                case "real":
                case "float4":
                    ParseFloat(value);
                    break;

                case "double precision":
                case "float8":
                    ParseDouble(value);
                    break;

                case "boolean":
                case "bool":
                    ParseBoolean(value);
                    break;

                case "date":
                    DateOnly.Parse(value, CultureInfo.InvariantCulture);
                    break;

                case "time":
                case "time without time zone":
                    TimeOnly.Parse(value, CultureInfo.InvariantCulture);
                    break;

                case "timestamp":
                case "timestamp without time zone":
                case "timestamptz":
                case "timestamp with time zone":
                    DateTime.Parse(value, CultureInfo.InvariantCulture);
                    break;

                case "uuid":
                    Guid.Parse(value);
                    break;
            }
        }
        catch (FormatException)
        {
            return $"Неверный формат для типа {col.DataType}";
        }

        return null;
    }


    private object ConvertValue(string value, ColumnInfo col)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        try
        {
            return col.DataType.ToLowerInvariant() switch
            {
                "integer" or "int" or "int4" => ParseInt(value),
                "smallint" or "int2" => (short)ParseInt(value),
                "bigint" or "int8" => ParseLong(value),
            
                "numeric" or "decimal" => ParseDecimal(value),
                "real" or "float4" => ParseFloat(value),
                "double precision" or "float8" => ParseDouble(value),
            
                "boolean" or "bool" => ParseBoolean(value),
            
                "date" => ParseDate(value),
                "time" or "time without time zone" => ParseTime(value),
                "timestamp" or "timestamp without time zone" => ParseDateTime(value),
                "timestamptz" or "timestamp with time zone" => ParseDateTime(value),
            
                "uuid" => Guid.Parse(value),
                _ => value
            };
        }
        catch (FormatException ex)
        {
            throw new InvalidOperationException($"Ошибка преобразования поля {col.ColumnName}: {ex.Message}", ex);
        }
    }

    private bool ParseBoolean(string value)
    {
        return value.ToLowerInvariant() switch
        {
            "true" or "1" or "yes" or "да" or "t" => true,
            "false" or "0" or "no" or "нет" or "f" => false,
            _ => bool.Parse(value)
        };
    }

    private T ParseNumber<T>(string value, string dataType) where T : struct
    {
        if (string.IsNullOrWhiteSpace(value))
            throw new ArgumentNullException(nameof(value));

        // Убираем пробелы и заменяем запятую на точку для единообразия
        value = value.Trim().Replace(',', '.');

        try
        {
            // Для целых чисел
            if (typeof(T) == typeof(int) || typeof(T) == typeof(long) ||
                typeof(T) == typeof(short) || typeof(T) == typeof(byte))
            {
                // Сначала пробуем парсить как есть
                if (typeof(T) == typeof(int) && int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var intResult))
                    return (T)(object)intResult;
                if (typeof(T) == typeof(long) && long.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var longResult))
                    return (T)(object)longResult;
                if (typeof(T) == typeof(short) && short.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var shortResult))
                    return (T)(object)shortResult;

                // Если не получилось, возможно есть десятичная часть - пробуем отбросить
                if (value.Contains('.'))
                {
                    var intPart = value.Split('.')[0];
                    if (typeof(T) == typeof(int) && int.TryParse(intPart, NumberStyles.Integer, CultureInfo.InvariantCulture, out var intResult2))
                        return (T)(object)intResult2;
                }
            }
            // Для чисел с плавающей точкой
            else if (typeof(T) == typeof(decimal) || typeof(T) == typeof(float) || typeof(T) == typeof(double))
            {
                if (typeof(T) == typeof(decimal) && decimal.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var decResult))
                    return (T)(object)decResult;
                if (typeof(T) == typeof(float) && float.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var floatResult))
                    return (T)(object)floatResult;
                if (typeof(T) == typeof(double) && double.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var doubleResult))
                    return (T)(object)doubleResult;
            }
        }
        catch (Exception ex)
        {
            throw new FormatException($"Не удалось преобразовать '{value}' в {typeof(T).Name}", ex);
        }

        throw new FormatException($"Не удалось преобразовать '{value}' в {typeof(T).Name}");
    }

    // Специализированные методы для каждого типа
    private int ParseInt(string value)
    {
        value = value.Trim().Replace(',', '.');

        // Пробуем прямой парсинг
        if (int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var result))
            return result;

        // Если есть десятичная часть, пробуем отбросить
        if (value.Contains('.'))
        {
            var intPart = value.Split('.')[0];
            if (int.TryParse(intPart, NumberStyles.Integer, CultureInfo.InvariantCulture, out result))
                return result;
        }

        throw new FormatException($"Не удалось преобразовать '{value}' в целое число");
    }

    private long ParseLong(string value)
    {
        value = value.Trim().Replace(',', '.');

        if (long.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var result))
            return result;

        if (value.Contains('.'))
        {
            var intPart = value.Split('.')[0];
            if (long.TryParse(intPart, NumberStyles.Integer, CultureInfo.InvariantCulture, out result))
                return result;
        }

        throw new FormatException($"Не удалось преобразовать '{value}' в целое число");
    }

    private decimal ParseDecimal(string value)
    {
        value = value.Trim().Replace(',', '.');

        // Пробуем прямой парсинг
        if (decimal.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var result))
            return result;

        // Пробуем заменить точку на запятую и наоборот
        if (value.Contains('.'))
        {
            if (decimal.TryParse(value.Replace('.', ','), NumberStyles.Any, CultureInfo.CurrentCulture, out result))
                return result;
        }
        else if (value.Contains(','))
        {
            if (decimal.TryParse(value.Replace(',', '.'), NumberStyles.Any, CultureInfo.InvariantCulture, out result))
                return result;
        }

        throw new FormatException($"Не удалось преобразовать '{value}' в десятичное число");
    }

    private float ParseFloat(string value)
    {
        value = value.Trim().Replace(',', '.');

        if (float.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var result))
            return result;

        throw new FormatException($"Не удалось преобразовать '{value}' в число с плавающей точкой");
    }

    private double ParseDouble(string value)
    {
        value = value.Trim().Replace(',', '.');

        if (double.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var result))
            return result;

        throw new FormatException($"Не удалось преобразовать '{value}' в число с плавающей точкой");
    }

    private DateTime ParseDate(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            throw new FormatException("Дата не может быть пустой");

        value = value.Trim();

        try
        {
            // Пробуем распарсить как DateOnly с инвариантной культурой (ожидает YYYY-MM-DD)
            if (DateOnly.TryParse(value, out var dateResult))
                return dateResult.ToDateTime(TimeOnly.MinValue);

            // Пробуем распарсить как DateTime и взять дату
            if (DateTime.TryParse(value, CultureInfo.CurrentCulture, out var dateTimeResult))
                return dateTimeResult.Date;

            // Пробуем различные форматы вручную
            var formats = new[]
            {
            "yyyy-MM-dd",
            "dd.MM.yyyy",
            "dd/MM/yyyy",
            "MM/dd/yyyy",
            "yyyyMMdd",
            "dd-MM-yyyy",
            "dd MMM yyyy",
            "d MMM yyyy"
            };

            if (DateOnly.TryParseExact(value, formats, CultureInfo.InvariantCulture, DateTimeStyles.None, out dateResult))
                return dateResult.ToDateTime(TimeOnly.MinValue);

            // Последняя попытка - заменить разделители
            var normalized = value.Replace('/', '-').Replace('.', '-');
            if (DateOnly.TryParseExact(normalized, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out dateResult))
                return dateResult.ToDateTime(TimeOnly.MinValue);

            throw new FormatException($"Не удалось распознать дату '{value}'. Ожидаемые форматы: ГГГГ-ММ-ДД, ДД.ММ.ГГГГ, ДД/ММ/ГГГГ");
        }
        catch (Exception ex)
        {
            throw new FormatException($"Ошибка парсинга даты '{value}': {ex.Message}", ex);
        }
    }

    private TimeSpan ParseTime(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            throw new FormatException("Время не может быть пустым");

        value = value.Trim();

        // Пробуем распарсить как TimeOnly
        if (TimeOnly.TryParse(value, out var timeOnly))
        {
            return timeOnly.ToTimeSpan();
        }

        // Пробуем распарсить как TimeSpan
        if (TimeSpan.TryParse(value, out var timeSpan))
        {
            return timeSpan;
        }

        throw new FormatException($"Не удалось распознать время '{value}'");
    }

    private DateTime ParseDateTime(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            throw new FormatException("Дата и время не могут быть пустыми");

        value = value.Trim();

        // Пробуем распарсить как DateTime
        if (DateTime.TryParse(value, out var dateTime))
        {
            return dateTime;
        }

        // Пробуем разные форматы
        var formats = new[]
        {
        "yyyy-MM-dd HH:mm:ss",
        "dd.MM.yyyy HH:mm:ss",
        "yyyy-MM-ddTHH:mm:ss",
        "dd.MM.yyyy",
        "yyyy-MM-dd"
    };

        if (DateTime.TryParseExact(value, formats, CultureInfo.InvariantCulture, DateTimeStyles.None, out dateTime))
        {
            return dateTime;
        }

        throw new FormatException($"Не удалось распознать дату/время '{value}'");
    }

}